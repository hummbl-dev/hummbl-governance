{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/hummbl-repo-manifest@0.1.schema.json",
  "title": "HUMMBL Repo Manifest",
  "description": "Machine-readable registry atom for a hummbl-dev repository. Declares identity, purpose, authority, governance profile, validation, and doc paths. Not a receipt, not a constitution.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "repo", "purpose", "authority", "governance", "validation", "docs"],
  "properties": {
    "schema": { "const": "hummbl-repo-manifest@0.1", "description": "Manifest schema version." },
    "repo": {
      "type": "object", "additionalProperties": false,
      "required": ["full_name", "name", "visibility", "default_branch", "status"],
      "properties": {
        "full_name": { "type": "string", "pattern": "^hummbl-dev/[A-Za-z0-9._-]+$" },
        "name": { "type": "string" },
        "visibility": { "enum": ["public", "private"] },
        "default_branch": { "type": "string", "default": "main" },
        "status": { "enum": ["active", "draft", "archived", "fork", "experimental"] },
        "naming": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional naming-policy exception record for repos that intentionally do not use the default hummbl- prefix.",
          "required": [
            "hummbl_prefix_exception",
            "exception_class",
            "exception_reason",
            "approved_by",
            "approved_at",
            "owning_standard",
            "allowed_scope",
            "forbidden_scope",
            "rename_or_archive_trigger"
          ],
          "properties": {
            "hummbl_prefix_exception": { "type": "boolean", "default": false },
            "exception_class": {
              "type": "string",
              "enum": ["authored_artifact", "protocol", "reference_archive", "research_object"]
            },
            "exception_reason": { "type": "string" },
            "approved_by": { "type": "string" },
            "approved_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owning_standard": { "type": "string", "const": "HUMMBL Repo Standard" },
            "allowed_scope": { "type": "string" },
            "forbidden_scope": { "type": "string" },
            "rename_or_archive_trigger": { "type": "string" }
          }
        }
      }
    },
    "purpose": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "summary", "source_of_record"],
      "properties": {
        "type": { "enum": ["spec", "app", "library", "research", "docs", "fork", "archive", "infra"] },
        "summary": { "type": "string", "maxLength": 280 },
        "source_of_record": { "const": "git" }
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["steward", "approving_human", "agents_file"],
      "properties": {
        "steward": { "type": "string" },
        "approving_human": { "type": "string" },
        "codeowners": {
          "type": "string",
          "default": "CODEOWNERS",
          "enum": ["CODEOWNERS", ".github/CODEOWNERS"],
          "description": "Path to the CODEOWNERS file. Both root 'CODEOWNERS' and '.github/CODEOWNERS' are valid per HUMMBL Repo Standard. The declared path must point to an existing file."
        },
        "agents_file": { "const": "AGENTS.md" }
      }
    },
    "governance": {
      "type": "object", "additionalProperties": false,
      "required": ["agents_required", "krineia_required", "model_provider_neutral"],
      "properties": {
        "agents_required": { "type": "boolean" },
        "krineia_required": { "type": "boolean" },
        "receipts_dir": { "type": "string", "default": "_receipts/" },
        "handoffs_dir": { "type": "string", "default": "docs/handoffs/" },
        "adr_dir": { "type": "string", "default": "docs/adr/" },
        "model_provider_neutral": { "type": "boolean", "const": true,
          "description": "Root governance must be provider-neutral. Always true." }
      }
    },
    "validation": {
      "type": "object", "additionalProperties": false,
      "required": ["command", "required_before_merge", "required_before_release"],
      "properties": {
        "command": { "type": "string", "description": "Deterministic admission gate command." },
        "required_before_merge": { "type": "boolean" },
        "required_before_release": { "type": "boolean" }
      }
    },
    "docs": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "readme": { "const": "README.md" },
        "constitution": { "type": "string", "default": "CONSTITUTION.md" },
        "doctrine": { "type": "string", "default": "DOCTRINE.md" },
        "agents": { "const": "AGENTS.md" },
        "krineia": { "const": "KRINEIA.md" },
        "contributing": { "const": "CONTRIBUTING.md" },
        "security": { "const": "SECURITY.md" },
        "changelog": { "const": "CHANGELOG.md" }
      }
    },
    "krineia": {
      "type": "object", "additionalProperties": false,
      "description": "Present only when governance.krineia_required is true.",
      "properties": {
        "manifest": { "const": "KRINEIA.md" },
        "chains": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["chain_id", "storage", "hash_algorithm"],
            "properties": {
              "chain_id": { "type": "string" },
              "storage": { "type": "string", "pattern": "^_receipts/" },
              "genesis_policy": { "type": "string" },
              "hash_algorithm": { "enum": ["sha256"] },
              "canonicalization": { "type": "string" }
            }
          }
        },
        "operators_allowed": { "type": "array", "items": { "enum": ["append", "project", "cut"] }, "minItems": 3, "uniqueItems": true },
        "operators_forbidden": { "type": "array", "items": { "type": "string" } },
        "validator": { "type": "string", "description": "Path or command to chain verifier." }
      }
    },
    "repository_settings": {
      "type": "object",
      "additionalProperties": false,
      "description": "Expected GitHub repository settings policy. Distinguishes declared policy from observed GitHub state. Audit tools compare these against live GitHub metadata.",
      "properties": {
        "default_branch": {
          "type": "string",
          "description": "Expected default branch name."
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "internal"],
          "description": "Expected repo visibility."
        },
        "archived": {
          "type": "boolean",
          "default": false,
          "description": "Whether the repo is expected to be archived."
        },
        "merge_methods": {
          "type": "object",
          "additionalProperties": false,
          "description": "Allowed merge methods on GitHub.",
          "properties": {
            "merge": { "type": "boolean", "default": false },
            "squash": { "type": "boolean", "default": true },
            "rebase": { "type": "boolean", "default": false }
          }
        },
        "allow_auto_merge": {
          "type": "boolean",
          "default": false,
          "description": "Whether auto-merge is allowed. Policy declaration — audit compares against GitHub state."
        },
        "allow_update_branch": {
          "type": "boolean",
          "default": false,
          "description": "Whether branch update (merge base branch into PR) is allowed."
        },
        "delete_branch_on_merge": {
          "type": "boolean",
          "default": true,
          "description": "Whether head branches are deleted after merge."
        },
        "branch_protection": {
          "type": "object",
          "additionalProperties": false,
          "description": "Branch protection policy evidence.",
          "properties": {
            "protected_branches": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of branch names expected to be protected."
            },
            "required_status_checks": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Required CI checks before merge."
            },
            "enforce_admins": {
              "type": "boolean",
              "default": true,
              "description": "Whether branch protection applies to admins."
            },
            "require_pull_request_reviews": {
              "type": "boolean",
              "default": false,
              "description": "Whether PR reviews are required."
            }
          }
        },
        "settings_authority": {
          "type": "string",
          "enum": ["operator-only", "steward", "shared"],
          "default": "operator-only",
          "description": "Who has authority to change repository settings."
        }
      }
    }
  }
}
