{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/evidence-readiness-review-receipt.v0.1.json",
  "title": "Evidence Readiness Review Receipt v0.1",
  "description": "Review disposition receipt for evidence-readiness packets. This schema must not contain raw confidential evidence, prompts, privileged facts, or secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "created_at",
    "matter_id",
    "data_classification",
    "intended_audience",
    "packet_paths",
    "source_manifest_ref",
    "reviewer",
    "verdict",
    "findings",
    "claim_honesty",
    "relay_decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence-readiness-review-receipt.v0.1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "matter_id": {
      "type": "string",
      "minLength": 1
    },
    "data_classification": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "PUBLIC_SYNTHETIC",
        "INTERNAL",
        "CLIENT_CONFIDENTIAL",
        "HIGHLY_SENSITIVE"
      ]
    },
    "intended_audience": {
      "type": "string",
      "enum": [
        "attorney",
        "client",
        "operator",
        "internal",
        "public"
      ]
    },
    "packet_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_manifest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "critical_peer",
            "attorney",
            "operator",
            "paralegal",
            "system"
          ]
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE_FOR_RELAY",
        "APPROVE_WITH_P2",
        "BLOCKED_P1",
        "BLOCKED_P0"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "item",
          "status",
          "summary"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "item": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "OPEN",
              "FIXED",
              "FIXED_IN_RELAY_SAFE",
              "WONT_FIX",
              "UNKNOWN"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "claim_honesty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unsupported_claims",
        "interpretations_labeled",
        "legal_questions_reserved_for_counsel",
        "public_use_approved"
      ],
      "properties": {
        "unsupported_claims": {
          "type": "integer",
          "minimum": 0
        },
        "interpretations_labeled": {
          "type": "boolean"
        },
        "legal_questions_reserved_for_counsel": {
          "type": "boolean"
        },
        "public_use_approved": {
          "type": "boolean"
        }
      }
    },
    "relay_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "conditions"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
