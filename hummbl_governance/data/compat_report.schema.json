{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/eal.compat.report.v1.json",
  "title": "EAL Compatibility Report v1",
  "description": "Deterministic compatibility classification report for two contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "classification",
    "primary_reason_code",
    "reason_codes",
    "contract_a_ref",
    "contract_b_ref",
    "diff_summary",
    "evaluator_profile"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "eal.compat.report.v1"
    },
    "classification": {
      "type": "string",
      "enum": [
        "BACKWARD_COMPATIBLE",
        "CONDITIONAL",
        "INCOMPATIBLE"
      ]
    },
    "primary_reason_code": {
      "$ref": "#/$defs/reason_code"
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/reason_code"
      }
    },
    "contract_a_ref": {
      "$ref": "#/$defs/contract_ref"
    },
    "contract_b_ref": {
      "$ref": "#/$defs/contract_ref"
    },
    "diff_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions_added",
        "actions_removed",
        "constraints_added",
        "constraints_removed",
        "constraints_tightened",
        "constraints_loosened",
        "risk_increased",
        "risk_decreased",
        "semantics_changed"
      ],
      "properties": {
        "actions_added": {
          "$ref": "#/$defs/string_array"
        },
        "actions_removed": {
          "$ref": "#/$defs/string_array"
        },
        "constraints_added": {
          "$ref": "#/$defs/string_array"
        },
        "constraints_removed": {
          "$ref": "#/$defs/string_array"
        },
        "constraints_tightened": {
          "$ref": "#/$defs/string_array"
        },
        "constraints_loosened": {
          "$ref": "#/$defs/string_array"
        },
        "risk_increased": {
          "$ref": "#/$defs/string_array"
        },
        "risk_decreased": {
          "$ref": "#/$defs/string_array"
        },
        "semantics_changed": {
          "type": "boolean"
        }
      }
    },
    "evaluator_profile": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "contract_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_hash"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "contract_hash": {
          "type": "string",
          "pattern": "^sha256:.+"
        }
      }
    },
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "COMPAT_BACKWARD_ONLY_RELAX_OR_ADD",
        "COMPAT_ACTION_REMOVED",
        "COMPAT_SEMANTICS_CHANGED",
        "COMPAT_CONSTRAINT_ADDED",
        "COMPAT_CONSTRAINT_TIGHTENED",
        "COMPAT_RISK_INCREASED"
      ]
    },
    "conditional_reason_code": {
      "type": "string",
      "enum": [
        "COMPAT_CONSTRAINT_ADDED",
        "COMPAT_CONSTRAINT_TIGHTENED",
        "COMPAT_RISK_INCREASED"
      ]
    },
    "incompatible_reason_code": {
      "type": "string",
      "enum": [
        "COMPAT_ACTION_REMOVED",
        "COMPAT_SEMANTICS_CHANGED"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "classification": {
            "const": "BACKWARD_COMPATIBLE"
          }
        }
      },
      "then": {
        "properties": {
          "primary_reason_code": {
            "const": "COMPAT_BACKWARD_ONLY_RELAX_OR_ADD"
          },
          "reason_codes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "prefixItems": [
              {
                "const": "COMPAT_BACKWARD_ONLY_RELAX_OR_ADD"
              }
            ],
            "items": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "classification": {
            "const": "CONDITIONAL"
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "primary_reason_code": {
                "const": "COMPAT_CONSTRAINT_ADDED"
              },
              "reason_codes": {
                "contains": {
                  "const": "COMPAT_CONSTRAINT_ADDED"
                },
                "minContains": 1
              }
            }
          },
          {
            "properties": {
              "primary_reason_code": {
                "const": "COMPAT_CONSTRAINT_TIGHTENED"
              },
              "reason_codes": {
                "contains": {
                  "const": "COMPAT_CONSTRAINT_TIGHTENED"
                },
                "minContains": 1
              }
            }
          },
          {
            "properties": {
              "primary_reason_code": {
                "const": "COMPAT_RISK_INCREASED"
              },
              "reason_codes": {
                "contains": {
                  "const": "COMPAT_RISK_INCREASED"
                },
                "minContains": 1
              }
            }
          }
        ],
        "properties": {
          "primary_reason_code": {
            "$ref": "#/$defs/conditional_reason_code"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/conditional_reason_code"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "classification": {
            "const": "INCOMPATIBLE"
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "primary_reason_code": {
                "const": "COMPAT_ACTION_REMOVED"
              },
              "reason_codes": {
                "contains": {
                  "const": "COMPAT_ACTION_REMOVED"
                },
                "minContains": 1
              }
            }
          },
          {
            "properties": {
              "primary_reason_code": {
                "const": "COMPAT_SEMANTICS_CHANGED"
              },
              "reason_codes": {
                "contains": {
                  "const": "COMPAT_SEMANTICS_CHANGED"
                },
                "minContains": 1
              }
            }
          }
        ],
        "properties": {
          "primary_reason_code": {
            "$ref": "#/$defs/incompatible_reason_code"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/incompatible_reason_code"
            }
          }
        }
      }
    }
  ]
}
