{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/eal.receipt.v1.json",
  "title": "EAL Receipt v1",
  "description": "Minimal receipt schema for deterministic EAL validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "execution_id",
    "contract_ref",
    "epoch_ref",
    "actions",
    "evidence",
    "integrity",
    "signature"
  ],
  "properties": {
    "receipt_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "contract_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_version",
        "contract_sha256"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "contract_version": {
          "type": "string",
          "minLength": 1
        },
        "contract_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "epoch_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "epoch_id",
        "epoch_number"
      ],
      "properties": {
        "epoch_id": {
          "type": "string",
          "minLength": 1
        },
        "epoch_number": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "action_id",
          "params_c14n_sha256",
          "boundary_assertion"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "params_c14n_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "params_inline": {
            "type": "object"
          },
          "params_evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "boundary_assertion": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "decision"
            ],
            "properties": {
              "decision": {
                "type": "string",
                "enum": [
                  "ALLOW",
                  "DENY"
                ]
              },
              "basis": {
                "type": "string",
                "enum": [
                  "POLICY_MATCH",
                  "CAPABILITY_CHECK",
                  "RISK_LIMIT",
                  "UNKNOWN"
                ]
              }
            }
          }
        },
        "anyOf": [
          {
            "required": [
              "params_inline"
            ]
          },
          {
            "required": [
              "params_evidence_id"
            ]
          }
        ]
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "kind",
          "sha256"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "PLAN_HASH",
              "TOOL_CALL_HASH",
              "TOOL_RESULT_HASH",
              "BUS_ENTRY_HASH",
              "ENV_FINGERPRINT",
              "PARAMS_BLOB"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_c14n_sha256"
      ],
      "properties": {
        "receipt_c14n_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "prev_receipt_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "kid",
        "sig"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "enum": [
            "ed25519"
          ]
        },
        "kid": {
          "type": "string",
          "minLength": 1
        },
        "sig": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "bus_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_start",
        "segment_end"
      ],
      "properties": {
        "segment_start": {
          "type": "integer",
          "minimum": 0
        },
        "segment_end": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
