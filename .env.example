# HUMMBL Governance Environment Variables
# Copy to .env and fill in values (do NOT commit .env)
#
# Sensitivity markers:
#   [SECRET]   — API keys, tokens, passwords (never share)
#   [PUBLIC]   — Client-side safe
#   [OPTIONAL] — Not required for basic operation

# ============================================================================
# Core State Directories (optional overrides for default paths)
# ============================================================================
# GOVERNANCE_STATE_DIR=.governance          # [OPTIONAL] Governance state directory
# HUMMBL_KERNEL_STATE_DIR=.kernel           # [OPTIONAL] Kernel state directory
# HUMMBL_CORPUS_DIR=.corpus                 # [OPTIONAL] Corpus data directory
# HUMMBL_KERNEL_ATLAS_DIR=.atlas            # [OPTIONAL] Atlas/law engine directory
# HUMMBL_MODEL_REGISTRY_PATH=models.json    # [OPTIONAL] Model registry file path

# ============================================================================
# MCP / Sandbox / Audit Directories
# ============================================================================
# MONITOR_STATE_DIR=/tmp/hummbl-monitor     # [OPTIONAL] Agent monitor state
# SANDBOX_STATE_DIR=/tmp/hummbl-sandbox     # [OPTIONAL] Sandbox execution state
# GOVERNANCE_AUDIT_DIR=/tmp/governance/audit # [OPTIONAL] Compliance audit output

# ============================================================================
# Secrets (required for delegation token signing and HMAC operations)
# ============================================================================
# HUMMBL_SIGNING_SECRET=your-secret-here    # [SECRET] HMAC signing secret
# DCT_SECRET=your-secret-here               # [SECRET] Fallback delegation token secret

# ============================================================================
# Test Overrides
# ============================================================================
# ENABLE_IDP=true                           # [OPTIONAL] Enable IDP feature-flagged tests
# XDG_DATA_HOME=~/.local/share             # [OPTIONAL] XDG data home override
