{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/memory-system-registry.v0.1-candidate.json",
  "title": "Memory System Registry v0.1 Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "schema_version",
    "status",
    "owner",
    "decision_authority",
    "authoritative_artifact",
    "markdown_companion",
    "purpose",
    "evidence",
    "repo_roots",
    "categories",
    "entries",
    "repo_candidates",
    "promotion_gate",
    "non_goals"
  ],
  "properties": {
    "object_type": { "const": "HUMMBL.MemorySystemRegistry" },
    "schema_version": { "const": "0.1-candidate" },
    "status": { "enum": ["PROPOSED", "CANDIDATE", "CANONICAL", "DEPRECATED"] },
    "owner": { "type": "string", "minLength": 1 },
    "decision_authority": { "type": "string", "minLength": 1 },
    "authoritative_artifact": { "type": "string", "minLength": 1 },
    "markdown_companion": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "actor", "host", "commands"],
      "properties": {
        "observed_at": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "host": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["purpose", "workdir", "command", "result"],
            "properties": {
              "purpose": { "type": "string", "minLength": 1 },
              "workdir": { "type": "string", "minLength": 1 },
              "command": { "type": "string", "minLength": 1 },
              "result": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "repo_roots": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "minProperties": 1
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "status",
          "owner",
          "write_authority",
          "state_authority",
          "receipt_path",
          "promotion",
          "paths"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "category": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "write_authority": { "type": "string", "minLength": 1 },
          "state_authority": { "type": "string", "minLength": 1 },
          "receipt_path": { "type": "string", "minLength": 1 },
          "promotion": { "type": "string", "minLength": 1 },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["repo", "path", "path_type", "exists_checked", "exists"],
              "properties": {
                "repo": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "path_type": { "enum": ["file", "directory", "glob"] },
                "exists_checked": { "type": "boolean" },
                "exists": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "repo_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scope", "promotion_status"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "scope": { "type": "string", "minLength": 1 },
          "promotion_status": { "type": "string", "minLength": 1 }
        }
      }
    },
    "promotion_gate": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
