{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/deterministic-runtime-decision-boundary.schema.json",
  "title": "Deterministic Runtime Decision Boundary",
  "description": "Advisory schema for separating deterministic program authority from bounded model output. Draft only; not canon.",
  "type": "object",
  "required": [
    "schema_version",
    "boundary_id",
    "workflow_id",
    "controller",
    "model_allowed_outputs",
    "forbidden_model_authority",
    "approval_gate",
    "receipt_ref"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "boundary_id": {"type": "string", "pattern": "^drdb-[a-z0-9-]+$"},
    "workflow_id": {"type": "string", "minLength": 1},
    "controller": {"type": "string", "enum": ["program", "workflow", "human_operator"]},
    "model_allowed_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["classification", "extraction", "summary", "proposal", "ranking"]}
    },
    "forbidden_model_authority": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["loop_control", "termination", "approval_override", "irreversible_side_effect_approval"]}
    },
    "approval_gate": {
      "type": "object",
      "required": ["human_required_for", "reviewer_role"],
      "properties": {
        "human_required_for": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "enum": ["external_write", "spend", "credential_use", "regulated_action", "irreversible_effect"]}
        },
        "reviewer_role": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "receipt_ref": {"type": "string", "pattern": "^hummbl:receipt:[a-z0-9-]+$"}
  },
  "additionalProperties": false
}
